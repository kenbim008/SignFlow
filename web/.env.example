# =============================================================================
# SignProz Next.js — Supabase (required for @supabase/ssr clients)
# =============================================================================
# Copy this file to .env.local and fill in values from the Supabase dashboard:
#   https://supabase.com/dashboard → your project → Project Settings
#
# 1) Project URL
#    Settings → API → Project URL
#    Looks like: https://xxxxxxxxxxxx.supabase.co
#
# 2) Public API key (choose ONE approach)
#
#    (A) New publishable key (recommended)
#        Settings → API → API Keys → Publishable key
#        Starts with: sb_publishable_...
#
#    (B) Legacy anon key (still supported)
#        Settings → API → Project API keys → anon / public
#        Long JWT string — use NEXT_PUBLIC_SUPABASE_ANON_KEY below instead of publishable.
#
# Never put the service_role / secret key in NEXT_PUBLIC_* or client-side code.
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Use either publishable OR anon (this app accepts either):
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =============================================================================
# Optional: direct Postgres URL (only if you use Prisma/Drizzle in THIS app)
# =============================================================================
# Supabase → Project Settings → Database → Connection string → URI
# Use Session mode or Direct connection for migrations; pooler for many serverless conns.
# Do NOT commit real passwords. Set in Vercel / CI secrets only.
#
# DATABASE_URL=postgresql://postgres.[ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
