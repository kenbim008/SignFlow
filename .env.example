# PostgreSQL (required). Use Neon (https://neon.tech) free tier, Supabase, or local Docker.
# Example Neon: postgresql://USER:PASSWORD@EP-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/signproz"

PORT=3000
JWT_SECRET="change-this-to-a-long-random-string-in-production"
# Public site URL (used in welcome / referral links)
APP_PUBLIC_URL="http://localhost:3000"

ADMIN_EMAIL="admin@signproz.local"
ADMIN_PASSWORD="ChangeMe123!"

# Set to true to skip OTP email and accept verification without the emailed code (dev only; do not use in production)
BYPASS_OTP="false"

# -----------------------------------------------------------------------------
# Email (OTP, welcome, document notifications)
# -----------------------------------------------------------------------------
# Pick ONE approach: Resend (easiest) OR classic SMTP.
# If misconfigured, OTP is logged to the server console instead of returning HTTP 500.
#
# --- Option A: Resend (https://resend.com) — HTTP API, no SMTP ports ---
# Create an API key, verify a domain (or use onboarding@resend.dev for tests).
RESEND_API_KEY=""
# Optional; defaults to SMTP_FROM or SignProz <onboarding@resend.dev>
RESEND_FROM="SignProz <onboarding@resend.dev>"
#
# --- Option B: SMTP (Gmail, Outlook, SendGrid, Mailgun, SES, etc.) ---
# If RESEND_API_KEY is set, Resend is used and SMTP is ignored.
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
# Used for SMTP "from" and as fallback for Resend "from"
SMTP_FROM="SignProz <noreply@yourdomain.com>"
